# ===========================================
# S.Budget Environment Configuration
# ===========================================

# --- General ---
NODE_ENV=development

# --- API Gateway ---
API_GATEWAY_PORT=3000

# --- Auth Service ---
AUTH_SERVICE_PORT=3001
AUTH_DATABASE_URL=postgresql://sbudget:sbudget_pass@localhost:5432/auth_db
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# --- Transaction Service ---
TRANSACTION_SERVICE_PORT=3002
TRANSACTION_DATABASE_URL=postgresql://sbudget:sbudget_pass@localhost:5432/transaction_db

# --- AI Service ---
AI_SERVICE_PORT=3003
GOOGLE_CLOUD_VISION_API_KEY=your-google-cloud-vision-api-key
OPENAI_API_KEY=your-openai-api-key

# --- Insight Service ---
INSIGHT_SERVICE_PORT=3004
INSIGHT_DATABASE_URL=postgresql://sbudget:sbudget_pass@localhost:5432/insight_db

# --- RabbitMQ ---
RABBITMQ_URL=amqp://sbudget:sbudget_pass@localhost:5672

# --- Cloudinary ---
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# --- PostgreSQL (Docker) ---
POSTGRES_USER=sbudget
POSTGRES_PASSWORD=sbudget_pass
